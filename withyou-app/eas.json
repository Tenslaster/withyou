{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_WITHYOU_API": "https://crew.kingdom.forum/withyou"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_WITHYOU_API": "https://crew.kingdom.forum/withyou"
      }
    },
    "apk": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_WITHYOU_API": "https://crew.kingdom.forum/withyou"
      }
    },
    "production": {
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_WITHYOU_API": "https://crew.kingdom.forum/withyou"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
